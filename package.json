{
  "name": "oddsorbit",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:deploy": "anchor deploy",
    "sdk:generate": "bun run --cwd packages/sdk generate",
    "typecheck": "bun run --cwd packages/shared typecheck && bun run --cwd packages/sdk typecheck && bun run --cwd apps/web typecheck",
    "localnet": "solana-test-validator --reset --ledger .test-ledger",
    "setup:local": "bun run scripts/setup-localnet.ts",
    "dev:local": "bash scripts/dev-local.sh"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
