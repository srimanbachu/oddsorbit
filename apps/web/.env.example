# Devnet (default — no overrides needed)
VITE_RPC_URL=https://api.devnet.solana.com
VITE_CLUSTER=devnet

# Local-mode overrides are auto-written to .env.local by `bun run dev:local`.
# Manually set them only if you're running setup outside the dev script:
#
# VITE_DEV_MODE=true
# VITE_RPC_URL=http://127.0.0.1:8899
# VITE_CLUSTER=localnet
# VITE_WBTC_MINT=<mock mint pubkey>
# VITE_DEV_FAUCET_SECRET=<hex 64-byte secret key>
